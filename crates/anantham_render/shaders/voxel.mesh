#version 460
#extension GL_EXT_mesh_shader : require

// 1 Thread = 1 Quad. 16 threads per workgroup.
layout(local_size_x = 16, local_size_y = 1, local_size_z = 1) in;
// 16 quads * 4 vertices = 64 vertices. 16 quads * 2 triangles = 32 primitives.
layout(triangles, max_vertices = 64, max_primitives = 32) out;

struct GpuQuad {
    uint geometry_data;
    uint material_data;
};

struct GpuMeshlet {
    float chunk_x, chunk_y, chunk_z;
    float min_x, min_y, min_z;
    float max_x, max_y, max_z;
    uint quad_offset;
    uint quad_count;
    uint padding;
};

layout(std430, set = 0, binding = 0) readonly buffer QuadSSBO {
    GpuQuad quads[];
};

layout(std430, set = 0, binding = 1) readonly buffer MeshletSSBO {
    GpuMeshlet meshlets[];
};

layout(push_constant) uniform CameraData {
    mat4 view_proj;
} camera;

layout(location = 0) out vec3 out_color[];

void main() {
    uint meshlet_idx = gl_WorkGroupID.x;
    uint local_idx = gl_LocalInvocationID.x;

    GpuMeshlet meshlet = meshlets[meshlet_idx];

    // The first thread declares how much geometry this meshlet will emit
    if (local_idx == 0) {
        SetMeshOutputsEXT(meshlet.quad_count * 4, meshlet.quad_count * 2);
    }

    if (local_idx < meshlet.quad_count) {
        GpuQuad quad = quads[meshlet.quad_offset + local_idx];

        // --- Unpack Data ---
        uint min_x = quad.geometry_data & 0xFF;
        uint min_y = (quad.geometry_data >> 8) & 0xFF;
        uint min_z = (quad.geometry_data >> 16) & 0xFF;
        uint width = (quad.geometry_data >> 24) & 0xFF;

        uint height = quad.material_data & 0xFF;
        uint face_dir = (quad.material_data >> 8) & 0x07;
        uint mat_id = (quad.material_data >> 16) & 0xFFFF;

        vec3 base_pos = vec3(min_x, min_y, min_z) + vec3(meshlet.chunk_x, meshlet.chunk_y, meshlet.chunk_z);
        vec3 p0 = base_pos, p1 = base_pos, p2 = base_pos, p3 = base_pos;

        // --- Geometry Expansion ---
        if (face_dir == 4 || face_dir == 5) { // NegativeZ, PositiveZ
            // Axis 2. u=X, v=Y. width=X, height=Y.
            float z_offset = (face_dir == 5) ? 1.0 : 0.0;
            p0 += vec3(0, 0, z_offset);
            p1 += vec3(0, height, z_offset);
            p2 += vec3(width, height, z_offset);
            p3 += vec3(width, 0, z_offset);
        } else if (face_dir == 0 || face_dir == 1) { // NegativeX, PositiveX
            // Axis 0. u=Y, v=Z. width=Y, height=Z.
            float x_offset = (face_dir == 1) ? 1.0 : 0.0;
            p0 += vec3(x_offset, 0, 0);
            p1 += vec3(x_offset, width, 0); // Y += width
            p2 += vec3(x_offset, width, height); // Y += width, Z += height
            p3 += vec3(x_offset, 0, height); // Z += height
        } else { // NegativeY, PositiveY
            // Axis 1. u=Z, v=X. width=Z, height=X.
            float y_offset = (face_dir == 3) ? 1.0 : 0.0;
            p0 += vec3(0, y_offset, 0);
            p1 += vec3(0, y_offset, width); // Z += width
            p2 += vec3(height, y_offset, width); // X += height, Z += width
            p3 += vec3(height, y_offset, 0); // X += height
        }

        uint v_offset = local_idx * 4;
        uint i_offset = local_idx * 2;

        // --- Emit Vertices ---
        gl_MeshVerticesEXT[v_offset + 0].gl_Position = camera.view_proj * vec4(p0, 1.0);
        gl_MeshVerticesEXT[v_offset + 1].gl_Position = camera.view_proj * vec4(p1, 1.0);
        gl_MeshVerticesEXT[v_offset + 2].gl_Position = camera.view_proj * vec4(p2, 1.0);
        gl_MeshVerticesEXT[v_offset + 3].gl_Position = camera.view_proj * vec4(p3, 1.0);

        // --- Emit Primitives (Indices) ---
        // We will disable face culling in the Rust pipeline for the first test,
        // so winding order (CW vs CCW) won't hide faces right now.
        gl_PrimitiveTriangleIndicesEXT[i_offset + 0] = uvec3(v_offset + 0, v_offset + 1, v_offset + 2);
        gl_PrimitiveTriangleIndicesEXT[i_offset + 1] = uvec3(v_offset + 0, v_offset + 2, v_offset + 3);

        // --- Temporary Diagnostic Colors ---
        vec3 colors[6] = vec3[](
                vec3(0.8, 0.2, 0.2), vec3(1.0, 0.4, 0.4), // -X, +X (Reds)
                vec3(0.2, 0.8, 0.2), vec3(0.4, 1.0, 0.4), // -Y, +Y (Greens)
                vec3(0.2, 0.2, 0.8), vec3(0.4, 0.4, 1.0) // -Z, +Z (Blues)
            );

        out_color[v_offset + 0] = colors[face_dir];
        out_color[v_offset + 1] = colors[face_dir];
        out_color[v_offset + 2] = colors[face_dir];
        out_color[v_offset + 3] = colors[face_dir];
    }
}
